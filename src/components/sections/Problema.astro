---
const problems = [
  {
    icon: "📚",
    title: "La teoría no es suficiente",
    description:
      "Los ciclos formativos enseñan fundamentos, pero la industria real exige experiencia, criterio y contexto que ningún libro puede dar.",
  },
  {
    icon: "🔗",
    title: "La comunidad IT está fragmentada",
    description:
      "LinkedIn es demasiado formal. Twitter demasiado ruidoso. Reddit demasiado genérico. No existe un espacio pensado específicamente para devs.",
  },
  {
    icon: "🧭",
    title: "Los juniors navegan sin referentes",
    description:
      "Sin acceso a seniors reales, los desarrolladores en formación repiten errores evitables y tardan años en aprender lo que podría transmitirse en meses.",
  },
];

const solutions = [
  {
    label: "Mentoría orgánica",
    desc: "Los seniors comparten retos reales del día a día",
  },
  {
    label: "Comunidad enfocada",
    desc: "Solo devs y profesionales IT, sin ruido",
  },
  {
    label: "Aprendizaje real",
    desc: "Jerga técnica, arquitectura, decisiones de producto",
  },
  {
    label: "Feed relevante",
    desc: "Filtrado por tecnologías que te interesan",
  },
];
---

<section class="section" id="problema">
  <div class="container">
    <!-- Header de sección -->
    <div class="section-header reveal">
      <div class="section-label">01 · El Problema</div>
      <h2 class="section-title">
        La brecha entre estudiar<br />y trabajar es real
      </h2>
      <p class="section-subtitle">
        Millones de estudiantes de programación se gradúan cada año sin saber
        realmente cómo funciona la industria. Loop nace para cerrar esa
        distancia.
      </p>
    </div>

    <!-- Cards de problemas -->
    <div class="problems-grid">
      {
        problems.map((p, i) => (
          <div class={`card problem-card reveal reveal-delay-${i + 1}`}>
            <div class="problem-icon">{p.icon}</div>
            <h3 class="problem-title">{p.title}</h3>
            <p class="problem-desc">{p.description}</p>
          </div>
        ))
      }
    </div>

    <!-- Transición al proyecto -->
    <div class="solution-block reveal">
      <div class="solution-left">
        <div class="section-label">La solución</div>
        <h3 class="solution-title">
          Un espacio donde el conocimiento fluye entre generaciones de devs
        </h3>
        <p class="solution-desc">
          Loop no es otra red social genérica. Es una plataforma con identidad
          propia, pensada desde cero para el ecosistema IT, donde compartir
          conocimiento técnico es el propósito central.
        </p>
      </div>
      <div class="solution-right">
        {
          solutions.map((s, i) => (
            <div class={`solution-item reveal reveal-delay-${i + 1}`}>
              <div class="solution-check">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </div>
              <div>
                <div class="solution-item-label">{s.label}</div>
                <div class="solution-item-desc">{s.desc}</div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .section-header {
    margin-bottom: 56px;
    max-width: 600px;
  }

  /* Grid de problemas */
  .problems-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 64px;
  }

  .problem-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .problem-icon {
    font-size: 2rem;
    line-height: 1;
  }

  .problem-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--gris-01);
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .problem-desc {
    font-size: 0.9rem;
    color: var(--gris-03);
    line-height: 1.65;
  }

  /* Bloque solución */
  .solution-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
    background: var(--bg-02);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 48px;
    box-shadow: var(--shadow-md);
  }

  .solution-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--gris-01);
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin: 12px 0 16px;
  }

  .solution-desc {
    font-size: 0.9rem;
    color: var(--gris-03);
    line-height: 1.7;
  }

  .solution-right {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-top: 8px;
  }

  .solution-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .solution-check {
    width: 24px;
    height: 24px;
    background: var(--color-01);
    border: 1px solid var(--color-02);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary-color);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .solution-item-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--gris-01);
    margin-bottom: 2px;
  }

  .solution-item-desc {
    font-size: 0.82rem;
    color: var(--gris-04);
  }

  @media (max-width: 900px) {
    .problems-grid {
      grid-template-columns: 1fr;
    }
    .solution-block {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 32px;
    }
  }
</style>
